    totalPages={Math.ceil(filter.length / productsPerPage)}\n466:                 onPageChange={setCurrentPage}\n467:  
               totalItems={filter.length}\n468:                 itemsPerPage={productsPerPage}\n469:               
/>\n470:             </div>\n471:           )}\n472:         </div>\n473:       </div>\n474:     </div>\n475:   
);\n476: };\n477: \n478: export default Products;\nThe above content shows the entire, complete file contents of the 
